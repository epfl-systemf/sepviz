{
  "name": "sep-viz",
  "version": "0.1.0",
  "type": "module",
  "description": "Visualization library for separation-logic proofs",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./*": {
      "import": "./dist/*.js",
      "types": "./dist/*.d.ts"
    },
    "./sep-viz.css": "./dist/sep-viz.css"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest"
  },
  "peerDependencies": {
    "d3-graphviz": "^5.6.0",
    "d3-selection": "*"
  },
  "devDependencies": {
    "@types/d3-graphviz": "^2.6.10",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash.merge": "^4.6.9",
    "@types/node": "^24.12.2",
    "d3-selection": "^3.0.0",
    "lodash": "^4.17.21",
    "npm-run-all": "^4.1.5",
    "peggy": "^5.1.0",
    "prettier": "^3.6.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.15"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  }
}
