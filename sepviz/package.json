{
  "name": "sepviz",
  "version": "0.2.0",
  "type": "module",
  "description": "Visualization library for separation-logic proofs",
  "exports": {
    ".": {
      "import": "./dist/sepviz.js",
      "types": "./dist/sepviz.d.ts"
    },
    "./*": {
      "import": "./dist/*.js",
      "types": "./dist/*.d.ts"
    },
    "./sepviz.css": "./dist/sepviz.css"
  },
  "types": "./dist/sepviz.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "preview": "vite build",
    "test": "vitest"
  },
  "devDependencies": {
    "@types/d3-ease": "^3.0.2",
    "@types/d3-graphviz": "^2.6.10",
    "@types/d3-transition": "^1",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash.merge": "^4.6.9",
    "@types/node": "^24.12.2",
    "d3-selection": "*",
    "peggy": "^5.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.15"
  },
  "dependencies": {
    "d3-ease": "^3.0.1",
    "d3-graphviz": "^5.6.0",
    "d3-transition": "^3.0.1",
    "js-yaml": "^4.1.0",
    "lodash.merge": "^4.6.2"
  }
}
